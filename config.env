# Single source of truth for all knobs. Edit here, then `./deploy.sh`.
# Values are sourced by deploy.sh (bash) and rendered into /etc/ont-watchdog.conf
# on the router (busybox ash). Keep them shell-portable.

# Hosts
ROUTER_SSH="root@10.20.30.1"
TASMOTA_IP="10.20.30.15"

# Internet check — DOWN only if ALL targets fail
PING_TARGETS="1.1.1.1 8.8.8.8 9.9.9.9"
PING_TIMEOUT=3

# How many consecutive 1-min cron runs must fail before we act.
# With cron at every minute, 3 means ~3 min of sustained failure required.
CONSECUTIVE_FAILS_REQUIRED=3

# Relay-off duration. ONT needs caps drained for a clean cold boot.
POWER_OFF_SECONDS=15

# Cooldown after a power cycle. Doubles per attempt within the hour window,
# capped at MAX_COOLDOWN. 300 → 600 → 1200 → 1800.
# Gives the ONT a real chance to renegotiate before we touch it again.
BASE_COOLDOWN=300
MAX_COOLDOWN=1800

# Hard cap: never more than this many power cycles per rolling hour.
# Past this, log and back off — likely an ISP-side outage, not a stuck ONT.
ATTEMPTS_PER_HOUR_CAP=4
